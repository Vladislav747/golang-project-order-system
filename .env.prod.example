CONFIG_PATH=/app/config/prod.yaml

# Postgres на хосте (не в Docker). host.docker.internal — доступ из контейнера go-app к серверу.
POSTGRES_USER=orders
POSTGRES_PASSWORD=change_me
POSTGRES_DB=orders
DATABASE_URL=postgres://orders:change_me@host.docker.internal:5432/orders?sslmode=disable

KAFKA_BROKERS=broker:29092
KAFKA_TOPIC_ORDERS=orders.create
KAFKA_CONSUMER_GROUP=order-service

GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://orders:change_me@localhost:5432/orders?sslmode=disable
GOOSE_MIGRATION_DIR=./migrations
